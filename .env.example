# Monitoring
DATABASE_PATH=data/grid_monitor.db
POLL_INTERVAL_SECONDS=5
# Leave empty to auto-discover /sys/class/power_supply/AC.
POWER_SUPPLY_PATH=
SITE_NAME=Home Grid
TZ=America/Los_Angeles

# Dashboard HTTP authentication (set both or leave both empty)
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
# Display a low-battery warning below this level (does not shut down the laptop).
BATTERY_WARNING_PERCENT=15

# Optional named Cloudflare Tunnel UUID
CLOUDFLARE_TUNNEL_ID=

# Master notification switch (also controlled by the dashboard)
NOTIFICATION_ENABLED=false
# Telegram alert language: en or bn
NOTIFICATION_LANGUAGE=en

# Email delivery channel
EMAIL_NOTIFICATION_ENABLED=true
# SMTP settings (required when email delivery is enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-account@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-account@gmail.com
NOTIFICATION_TO_EMAIL=recipient@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Telegram delivery channel. Message the bot once before discovering the chat ID.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
