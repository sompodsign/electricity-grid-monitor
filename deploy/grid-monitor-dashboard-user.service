[Unit]
Description=Electricity Grid Monitor Reporting Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/Desktop/projects/electricity-grid-monitor
EnvironmentFile=%h/Desktop/projects/electricity-grid-monitor/.env
ExecStart=/usr/bin/python3 -m grid_monitor serve --host 0.0.0.0 --port 8090
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target
